[Unit]
Description=drone-companion web UI
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=drone
Group=drone
ExecStart=/opt/drone/venv/bin/uvicorn drone_ui.main:app --host 0.0.0.0 --port 80
AmbientCapabilities=CAP_NET_BIND_SERVICE
Environment=DRONE_TEMPLATES_DIR=/opt/drone/templates
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
