#!/usr/bin/env bash
# drone-update — pull latest main and re-run the installer
set -euo pipefail
if [ ! -d /opt/drone/.git ]; then
    echo "Not a git checkout at /opt/drone — can't auto-update." >&2
    exit 1
fi
cd /opt/drone
# /opt/drone is owned by the `drone` user but we're running as root via sudo.
# Whitelist the path so git's "dubious ownership" check doesn't reject us.
GIT="git -c safe.directory=/opt/drone"
$GIT fetch --depth=50 origin
$GIT reset --hard "origin/${DRONE_BRANCH:-main}"
exec /opt/drone/install.sh
